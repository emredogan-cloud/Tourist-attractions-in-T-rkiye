# --- Application ---
NODE_ENV=development
APP_URL=http://localhost:3000
PORT=3000
LOG_LEVEL=info

# --- Database ---
# Production: PostgreSQL with PostGIS
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/turkiye_tourism?schema=public
# Local zero-dep: SQLite (paths are relative to prisma/schema.prisma)
DATABASE_URL=file:./dev.db
DATABASE_PROVIDER=sqlite

# --- Cache / Queue ---
REDIS_URL=redis://localhost:6379

# --- Search ---
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_MASTER_KEY=masterKeyChangeMe
MEILISEARCH_SEARCH_KEY=

# --- Auth (Phase 5) ---
AUTH_PROVIDER=mock
AUTH_COOKIE_SECRET=changeMeAtLeast32CharactersLongPlease!!
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# --- Object Storage (Phase 1) ---
STORAGE_PROVIDER=local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# --- Maps (Phase 6) ---
NEXT_PUBLIC_MAP_PROVIDER=openfreemap
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- AI Concierge (Phase 10) ---
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_PREMIUM=claude-opus-4-7
OPENAI_API_KEY=

# --- Affiliate APIs (Phase 7) ---
NEARBY_PROVIDER_HOTELS=mock
NEARBY_PROVIDER_RESTAURANTS=mock
BOOKING_AFFILIATE_ID=
BOOKING_API_KEY=
FOURSQUARE_API_KEY=

# --- Email (Phase 4/5) ---
EMAIL_PROVIDER=mock
RESEND_API_KEY=
EMAIL_FROM="Türkiye Tourism <noreply@example.com>"

# --- Weather (Phase 12) ---
OPENWEATHER_API_KEY=

# --- Payments (Phase 15) ---
PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
IYZICO_API_KEY=
IYZICO_SECRET_KEY=

# --- Observability ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Feature Flags ---
FEATURE_AI_CONCIERGE=true
FEATURE_ITINERARIES=true
FEATURE_REVIEWS=true
FEATURE_PREMIUM=true
