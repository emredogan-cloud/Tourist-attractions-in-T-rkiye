{
  "expo": {
    "name": "Türkiye Travel",
    "slug": "turkiye-tourism",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "turkiye-tourism",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.turkiye-tourism",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We use your location to show nearby attractions.",
        "NSCameraUsageDescription": "Add photos to your reviews.",
        "NSPhotoLibraryUsageDescription": "Choose photos for your reviews.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": ["applinks:turkiye-tourism.app"]
    },
    "android": {
      "package": "app.turkiye_tourism",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"],
      "intentFilters": [
        {
          "action": "VIEW",
          "category": ["DEFAULT", "BROWSABLE"],
          "data": [
            { "scheme": "https", "host": "turkiye-tourism.app", "pathPrefix": "/attractions" }
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-notifications",
        {
          "color": "#E30A17"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "http://localhost:3000",
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
